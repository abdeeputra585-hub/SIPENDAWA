# EduGuardian - Konfigurasi Database
# Laragon default: root tanpa password

DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=eduguardian

# Mode Aplikasi
APP_ENV=development
APP_DEBUG=true

# Domain yang diizinkan (CORS)
ALLOWED_DOMAINS=http://localhost,http://127.0.0.1,http://uts_pemograman.test

# JWT Secret (ganti dengan string acak yang panjang di production)
JWT_SECRET=eduguardian_secret_key_2026_ganti_ini

# Google OAuth 2.0 Client ID
# Dapatkan di: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=GANTI_DENGAN_CLIENT_ID_ANDA.apps.googleusercontent.com
